# =====================================================================================
# RUNTIME STATE (machine-local data, not source)
# =====================================================================================
# SQLite databases and WAL files
state/
# Qdrant vector store (large binary index, rebuilt from source)
# (already covered by state/ above)

# =====================================================================================
# DOWNLOADED DOCUMENTATION (large, fetched at runtime via `fetch` command)
# =====================================================================================
docs_center/technologies/
# Project subscription files are runtime-generated by install_project
docs_center/projects/

# =====================================================================================
# PRIVATE DOCS (personal notes, agent memory, prompt history, architecture drafts)
# =====================================================================================
docs/

# =====================================================================================
# BACKUPS & LOCAL SCRIPTS (dev-session artefacts, not part of the product)
# =====================================================================================
zscripts/
backups/
scripts/

